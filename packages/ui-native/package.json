{
  "name": "theo-kit-native",
  "version": "0.0.3",
  "description": "React Native UI components for theo-kit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "nativewind": ">=4.0.0"
  },
  "dependencies": {
    "theo-kit-core": "^0.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "nativewind": ">=4.0.0",
    "react": "^18.3.0",
    "react-native": "^0.76.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "react-native",
    "expo",
    "nativewind",
    "ui",
    "components"
  ],
  "license": "MIT"
}
